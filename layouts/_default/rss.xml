{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
{{- printf "<?xml-stylesheet href=\"/rss-style.xsl\" type=\"text/xsl\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ .Site.Title }}</title>
    <link>{{ .Permalink }}</link>
    <description>Recent content on {{ .Site.Title }}</description>
    <generator>Hugo -- gohugo.io</generator>
    <language>{{ site.LanguageCode | default "ru" }}</language>
    
    {{/* Этот блок принудительно добавляет Меморандум в ленту, пока нет других постов */}}
    <item>
      <title>Protocol: Slow Living (Memorandum)</title>
      <link>{{ .Site.BaseURL }}</link>
      <pubDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      <guid>{{ .Site.BaseURL }}</guid>
      <description>Автономная инфраструктура и защита внимания в эпоху цифрового шума.</description>
    </item>

    {{/* Этот блок подтянет будущие посты из папки content/posts */}}
    {{ range (where .Site.RegularPages "Section" "posts") }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      <description>{{ .Summary | html }}</description>
    </item>
    {{ end }}
  </channel>
</rss>